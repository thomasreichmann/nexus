{
    "name": "nexus",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "turbo dev --filter=@nexus/web --output-logs=new-only --log-prefix=none",
        "build": "turbo build",
        "lint": "turbo lint",
        "test": "turbo test",
        "check": "node scripts/check.mjs",
        "check:verbose": "node scripts/check.mjs --verbose",
        "test:coverage": "turbo test:coverage && node scripts/coverage-summary.mjs",
        "coverage:open": "node scripts/coverage-summary.mjs --open",
        "test:e2e": "turbo test:e2e",
        "typecheck": "turbo typecheck",
        "env:pull": "vercel env pull apps/web/.env.local",
        "capture": "pnpm --filter @nexus/capture exec tsx src/cli.ts"
    },
    "devDependencies": {
        "prettier": "^3.8.0",
        "turbo": "^2.9.10"
    },
    "license": "ISC",
    "packageManager": "pnpm@10.26.2",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@sentry/cli",
            "sharp",
            "unrs-resolver"
        ],
        "ignoredBuiltDependencies": [
            "esbuild"
        ]
    }
}
